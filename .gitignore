# ─── Secrets (never track these) ─────────────────────────────────────────────
*-credentials.fish
*-credentials.sh
*.env
.env.*
secrets/

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─── Editors ──────────────────────────────────────────────────────────────────
.idea/
*.swp
*.swo

# ─── Claude / Pi runtime state (not config) ───────────────────────────────────
dotfiles/claude/todos/
dotfiles/claude/.claude_files
dotfiles/pi/.pi/cache/
dotfiles/pi/.pi/logs/

# ─── Neovim generated artifacts ───────────────────────────────────────────────
# lazy-lock.json is auto-regenerated by lazy.nvim on startup — not worth tracking
dotfiles/nvim/lazy-lock.json
